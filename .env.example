# SDN Platform Environment Configuration

# Server
PORT=5000
NODE_ENV=production

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sdn_platform
DB_USER=sdnuser
DB_PASSWORD=sdnpass123
DB_POOL_MAX=20
DB_IDLE_TIMEOUT=30000
DB_CONNECTION_TIMEOUT=2000

# Redis Cache
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
CACHE_TTL=300

# ONOS Controller
ONOS_HOST=localhost
ONOS_PORT=8181
ONOS_USER=karaf
ONOS_PASSWORD=karaf
ONOS_TIMEOUT_MS=8000

# Security
JWT_SECRET=your-secret-key-change-in-production-32-chars-minimum
JWT_EXPIRES_IN=8h
BCRYPT_SALT_ROUNDS=10

# CORS
CORS_ORIGIN=http://localhost:3000

# API
API_TIMEOUT=30000
MAX_REQUEST_SIZE=10mb

# Auto Sync
ENABLE_AUTO_SYNC=true
SYNC_INTERVAL_MS=5000
AUTO_SYNC_DEVICES=true
AUTO_SYNC_LINKS=true
AUTO_SYNC_FLOWS=true

# Admin User (Created on first run)
DEFAULT_ADMIN_FULL_NAME=DNA Center Admin
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_EMAIL=admin@sdn.local
DEFAULT_ADMIN_PASSWORD=admin123

# SSO - Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# SSO - Microsoft Azure AD
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# SSO - Okta
OKTA_CLIENT_ID=
OKTA_CLIENT_SECRET=
OKTA_DOMAIN=

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:5000/api
NEXT_PUBLIC_WS_URL=ws://localhost:5000
NEXT_PUBLIC_APP_NAME=SDN Platform

# Logging
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=/var/log/sdn-platform/app.log

# Monitoring
METRICS_ENABLED=true
METRICS_INTERVAL=60000
METRICS_RETENTION_DAYS=7

# Rate Limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=1000

# Backend URL (for SSO callbacks)
BACKEND_URL=http://localhost:5000

# Deployment
DOCKER_IMAGE_TAG=latest
KUBERNETES_NAMESPACE=sdn-platform

# Features
ENABLE_MULTI_TENANCY=true
ENABLE_SSO=false
ENABLE_AUDIT_LOGGING=true
ENABLE_METRICS=true
ENABLE_CACHE=true

# Development only
DEBUG=sdn-platform:*
MOCK_ONOS=false
MOCK_DATABASE=false
