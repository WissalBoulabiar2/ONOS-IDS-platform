{
  "testEnvironment": "node",
  "collectCoverage": true,
  "collectCoverageFrom": [
    "PlatformSDN/backend/**/*.js",
    "PlatformSDN/app/**/*.{js,jsx,ts,tsx}",
    "!**/node_modules/**",
    "!**/.next/**",
    "!**/coverage/**",
    "!**/dist/**",
    "!**/__tests__/**",
    "!**/config.js",
    "!**/server.js"
  ],
  "coverageThreshold": {
    "global": {
      "branches": 70,
      "functions": 70,
      "lines": 70,
      "statements": 70
    }
  },
  "testMatch": [
    "**/__tests__/**/*.js",
    "**/?(*.)+(spec|test).js"
  ],
  "setupFilesAfterEnv": [
    "<rootDir>/PlatformSDN/backend/__tests__/setup.js"
  ],
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/PlatformSDN/$1"
  },
  "testTimeout": 10000
}
