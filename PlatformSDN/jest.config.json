{
  "testEnvironment": "node",
  "collectCoverage": true,
  "collectCoverageFrom": [
    "PlatformSDN/backend/**/*.js",
    "!**/node_modules/**",
    "!**/coverage/**"
  ],
  "coverageThreshold": {
    "global": {
      "lines": 60
    }
  },
  "testMatch": [
    "**/__tests__/**/*.js",
    "**/?(*.)+(spec|test).js"
  ]
}
